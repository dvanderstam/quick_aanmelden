# Supabase credentials (vind je in Supabase Dashboard > Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nodig voor server-side teamadmin routes en bestaande reset/auth flows
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
EXPO_PUBLIC_DEFAULT_PASSWORD=choose-a-default-password

# Optioneel: base URL voor Netlify functions bij native/local gebruik.
# Laat leeg op web als functies op dezelfde host draaien.
# EXPO_PUBLIC_API_BASE_URL=https://your-site.netlify.app

# Optioneel: ICS proxy URL (voor productie op Netlify wordt /api/ics gebruikt)
# EXPO_PUBLIC_ICS_URL=/api/ics
