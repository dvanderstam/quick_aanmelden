# Supabase credentials (vind je in Supabase Dashboard > Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
EXPO_PUBLIC_DEFAULT_PASSWORD=Quick2026!
EXPO_PUBLIC_AUTH_EMAIL_DOMAINS=quick.local

# Optioneel: ICS proxy URL (voor productie op Netlify wordt /api/ics gebruikt)
# EXPO_PUBLIC_ICS_URL=/api/ics
